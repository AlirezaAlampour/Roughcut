FRONTEND_PORT=3000
BACKEND_PORT=8000
# Bind published ports to all host interfaces for trusted LAN access.
# Use 127.0.0.1 to keep the stack local-only on the Docker host.
FRONTEND_BIND_HOST=0.0.0.0
BACKEND_BIND_HOST=0.0.0.0
NEXT_PUBLIC_APP_TITLE=Roughcut

VIDEO_AGENT_DATABASE_PATH=/data/app.db
VIDEO_AGENT_STORAGE_ROOT=/data/projects
VIDEO_AGENT_CONFIG_ROOT=/data/config
VIDEO_AGENT_LOGS_ROOT=/data/logs

VIDEO_AGENT_DEFAULT_LLM_BASE_URL=http://host.docker.internal:11434
VIDEO_AGENT_DEFAULT_LLM_MODEL=qwen3:32b
VIDEO_AGENT_DEFAULT_PRESET=tacdel_builder_story
VIDEO_AGENT_DEFAULT_CUT_AGGRESSIVENESS=balanced
VIDEO_AGENT_DEFAULT_CAPTIONS_ENABLED=true
VIDEO_AGENT_DEFAULT_OUTPUT_QUALITY_PRESET=balanced
VIDEO_AGENT_ENABLE_DETAILED_PLANNER_LOGGING=true

VIDEO_AGENT_WHISPER_MODEL=small
VIDEO_AGENT_WHISPER_DEVICE=cpu
VIDEO_AGENT_WHISPER_COMPUTE_TYPE=int8
VIDEO_AGENT_MAX_UPLOAD_SIZE_MB=8192
VIDEO_AGENT_WORKER_POLL_INTERVAL_SECONDS=2
VIDEO_AGENT_LLM_REQUEST_TIMEOUT_SECONDS=180
